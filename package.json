{
  "name": "starbot",
  "version": "1.0.0",
  "description": "Discord Bot for Star Syndrome Server",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "deploy-panel": "tsx src/utils/deployPanel.ts",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "discord.js": "^14.15.3",
    "dotenv": "^16.4.5",
    "mongoose": "^8.4.3",
    "pdfkit": "^0.19.1",
    "picocolors": "^1.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@types/pdfkit": "^0.17.6",
    "@typescript-eslint/eslint-plugin": "^7.14.1",
    "@typescript-eslint/parser": "^7.14.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.2",
    "tsx": "^4.16.0",
    "typescript": "^5.5.2"
  }
}
